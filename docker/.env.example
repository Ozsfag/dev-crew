# ─── Anthropic API ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-CHANGE_ME

# ─── Telegram Bot (опционально) ───────────────────────────────────────────────
# Создать бота через @BotFather, получить token и chat_id
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── База данных ──────────────────────────────────────────────────────────────
DB_USERNAME=devcrew
DB_PASSWORD=change_me_in_prod

# ─── Локальная машина: путь к папке с проектами ───────────────────────────────
# Эта папка монтируется в контейнер как /projects
# На сервере не нужна — переопределяется в docker-compose.prod.yml
PROJECTS_ROOT=/path/to/your/projects
