# Скопируй в .env и заполни значения:
# cp .env.example .env

# Обязательные
DEVCREW_AUTH_JWT_SECRET=замени-на-случайную-строку-минимум-32-символа
PROJECTS_ROOT=/Users/ты/projects   # папка с проектами, которые будут открыты агентам

# БД (дефолтные значения подходят для локальной разработки)
DB_USERNAME=devcrew
DB_PASSWORD=devcrew

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
